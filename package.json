{
  "name": "yourdivorcerealtor-com",
  "author": "Dr. Jan Duffy — yourdivorcerealtor.com",
  "engines": {
    "node": ">=20"
  },
  "browserslist": [
    "Chrome >= 111",
    "Edge >= 111",
    "Firefox >= 111",
    "Safari >= 16.4",
    "iOS >= 16.4",
    "not dead"
  ],
  "scripts": {
    "dev:spotlight": "npx @spotlightjs/spotlight",
    "dev:next": "next dev",
    "dev": "npm-run-all db-remote:neon db:migrate --parallel dev:*",
    "build:next": "next build --webpack",
    "build-local": "run-p db-server:memory build:next --race",
    "build": "run-s migrate:optional build:next",
    "migrate:optional": "node scripts/migrate-optional.js",
    "start": "next start",
    "build-stats": "cross-env ANALYZE=true npm run build",
    "clean": "rimraf .next out coverage",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "check:types": "tsc --noEmit --pretty",
    "check:deps": "knip",
    "check:i18n": "i18n-check -l src/locales -s en -u src -f next-intl",
    "commit": "commit",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "db-remote:neon": "npx get-db --yes --env .env.local --ref nextjs-boilerplate",
    "neon:claim": "npx get-db claim --env .env.local --ref nextjs-boilerplate",
    "db-server:file": "pglite-server --db=local.db --run 'npm run db:migrate'",
    "db-server:memory": "pglite-server --run 'npm run db:migrate'",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "dotenv -c -- drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "storybook": "storybook dev -p 6006",
    "storybook:test": "vitest run --config .storybook/vitest.config.mts",
    "build-storybook": "storybook build"
  },
  "dependencies": {
    "@arcjet/next": "^1.3.1",
    "@clerk/localizations": "^3.37.3",
    "@clerk/nextjs": "^6.39.1",
    "@hookform/resolvers": "^5.2.2",
    "@logtape/logtape": "^1.3.7",
    "@sentry/nextjs": "^10.48.0",
    "@t3-oss/env-nextjs": "^0.13.11",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.37.0",
    "@vercel/speed-insights": "^1.3.1",
    "drizzle-orm": "^0.45.2",
    "next": "^16.2.3",
    "next-intl": "^4.9.1",
    "pg": "^8.20.0",
    "posthog-js": "^1.368.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-hook-form": "^7.72.1",
    "react-markdown": "^10.1.0",
    "tailwind-merge": "^3.5.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^6.7.3",
    "@chromatic-com/playwright": "^0.13.1",
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@commitlint/prompt-cli": "^20.5.0",
    "@electric-sql/pglite-socket": "^0.1.4",
    "@eslint-react/eslint-plugin": "^2.13.0",
    "@faker-js/faker": "^10.4.0",
    "@lingual/i18n-check": "^0.9.3",
    "@next/bundle-analyzer": "^16.2.3",
    "@next/eslint-plugin-next": "^16.2.3",
    "@playwright/test": "^1.59.1",
    "@spotlightjs/spotlight": "4.11.3",
    "@storybook/addon-a11y": "^10.3.5",
    "@storybook/addon-docs": "^10.3.5",
    "@storybook/addon-vitest": "^10.3.5",
    "@storybook/nextjs-vite": "^10.3.5",
    "@tailwindcss/postcss": "^4.2.2",
    "@types/node": "^24.12.2",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.14",
    "@vitejs/plugin-react": "^5.2.0",
    "@vitest/browser": "^4.1.4",
    "@vitest/browser-playwright": "^4.1.4",
    "@vitest/coverage-v8": "^4.1.4",
    "babel-plugin-react-compiler": "^1.0.0",
    "baseline-browser-mapping": "^2.10.18",
    "checkly": "^6.9.10",
    "conventional-changelog-conventionalcommits": "^9.1.0",
    "cross-env": "^10.1.0",
    "dotenv-cli": "^11.0.0",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9.39.4",
    "eslint-plugin-format": "^1.5.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-playwright": "^2.10.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "eslint-plugin-storybook": "^10.3.5",
    "eslint-plugin-tailwindcss": "^4.0.0-beta.0",
    "get-db": "^0.14.0",
    "knip": "^5.88.1",
    "lefthook": "^2.1.5",
    "npm-run-all": "^4.1.5",
    "postcss": "^8.5.9",
    "postcss-load-config": "^6.0.1",
    "rimraf": "^6.1.3",
    "semantic-release": "^25.0.3",
    "storybook": "^10.1.4",
    "tailwindcss": "^4.1.17",
    "typescript": "5.9.3",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^4.1.4",
    "vitest-browser-react": "^2.2.0"
  },
  "release": {
    "branches": [
      "main"
    ],
    "plugins": [
      [
        "@semantic-release/commit-analyzer",
        {
          "preset": "conventionalcommits"
        }
      ],
      "@semantic-release/release-notes-generator",
      "@semantic-release/github"
    ]
  }
}
